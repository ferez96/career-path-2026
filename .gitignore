# OS and editor artifacts
.DS_Store
Thumbs.db
*.tmp
*.swp
*~

# Python caches
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/

# Node and tool caches
node_modules/
.npm/
.yarn/
.cache/

# Logs
*.log
logs/

# Build and generated artifacts
dist/
build/
out/
exports/
artifacts/
tmp/
scratch/
*.bak
*.cache
*.out

# Secrets and local credentials
.env
.env.*
secrets/
credentials*.json

# Career-tracking sensitive raw inputs (keep local only)
# Raw JD/benchmark drops: only under data/raw/ (single ingest location)
data/raw/*
data/private/*
reports/private/*
!data/raw/.keep
!data/private/.keep
!reports/private/.keep

# Large or generated binaries
*.zip
*.7z
*.tar
*.gz
*.sqlite
*.db
